{
  "git": {
    "commitMessage": "chore: release v${version}"
  },
  "github": {
    "release": true
  },
  "npm": {
    "publishArgs": ["--provenance"]
  },
  "hooks": {
    "before:init": ["npm test"],
    "after:bump": "npm run build",
    "after:release": "cd docs && npm install && npm run build && npm run deploy"
  }
}
